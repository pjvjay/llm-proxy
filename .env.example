# ---- upstream ----
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---- guardrails service ----
GUARDRAILS_URL=http://guardrails:8000
GUARDRAILS_TIMEOUT=2.0
INJECTION_MODEL_DIR=/models/prompt-guard-2-onnx
TOXICITY_MODEL_DIR=/models/granite-hap-onnx
INJECTION_POS_LABEL=1
TOXICITY_POS_LABEL=1

# ---- thresholds (0.0-1.0) ----
INJECTION_THRESHOLD=0.5
TOXICITY_THRESHOLD=0.5

# ---- policy: action = block|redact|warn|log ; fail = closed|open ----
TOXICITY_ACTION=block
TOXICITY_FAIL=open
PII_ACTION=redact
